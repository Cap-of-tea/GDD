<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="using:GDD.Desktop.Views"
        x:Class="GDD.Desktop.Views.MainWindow"
        Title="GDD Desktop — Multi-Browser Testing"
        MinWidth="800" MinHeight="600"
        Width="1180" Height="760"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource BackgroundBrush}">

  <Grid RowDefinitions="Auto,*,Auto">

    <!-- Toolbar -->
    <Border Grid.Row="0" Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,8">
      <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
        <TextBlock VerticalAlignment="Center" Margin="0,0,14,0">
          <Run Text="GDD" FontSize="16" FontWeight="Bold" Foreground="#FF10B981" />
          <Run Text="{Binding Version}" FontSize="11" Foreground="#FF8C8C8C" />
        </TextBlock>

        <Button Content="+ Add Player" Classes="accent" Command="{Binding AddPlayerCommand}" />

        <Button Classes="toolbar" Content="+ Add ▾" Click="OnOpenAddMenu" />

        <Button Classes="toolbar" Content="Quick Auth" Command="{Binding QuickAuthAllCommand}" />
        <Button Classes="toolbar" Content="Close All" Command="{Binding CloseAllCommand}" />
        <Button Classes="toolbar" Content="? Help" Command="{Binding OpenHelpCommand}" Margin="0,0,12,0" />

        <TextBlock Text="URL:" Foreground="{DynamicResource TextSecondaryBrush}"
                   VerticalAlignment="Center" FontSize="12" Margin="0,0,6,0" />
        <TextBox Width="300" Text="{Binding DefaultUrl}" VerticalAlignment="Center"
                 Background="{DynamicResource SurfaceLightBrush}"
                 Foreground="{DynamicResource TextPrimaryBrush}" />
        <Button Classes="toolbar" Content="Go" Command="{Binding NavigateAllCommand}" />
      </StackPanel>
    </Border>

    <!-- Video Wall -->
    <Panel Grid.Row="1">
      <ItemsControl ItemsSource="{Binding Players}">
        <ItemsControl.ItemsPanel>
          <ItemsPanelTemplate>
            <views:VideoWallPanel />
          </ItemsPanelTemplate>
        </ItemsControl.ItemsPanel>
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <views:BrowserCellControl Margin="1" />
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <!-- Mascot easter egg: click to make the duckling peek out -->
      <Image x:Name="Mascot" Source="avares://GDD.Desktop/Assets/mascot.png"
             Width="180" Opacity="0.08"
             HorizontalAlignment="Left" VerticalAlignment="Center" Margin="24,0,0,0"
             PointerPressed="OnMascotClicked">
        <Image.Transitions>
          <Transitions>
            <DoubleTransition Property="Opacity" Duration="0:0:0.8" />
          </Transitions>
        </Image.Transitions>
      </Image>
    </Panel>

    <!-- Status Bar -->
    <Border Grid.Row="2" Background="{DynamicResource SurfaceBrush}"
            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0" Padding="12,4">
      <DockPanel>
        <TextBlock DockPanel.Dock="Right" Foreground="#FFD700" FontSize="11" VerticalAlignment="Center"
                   Margin="0,0,12,0" IsVisible="{Binding UpdateAvailable}"
                   Text="{Binding UpdateVersion, StringFormat='⚠ Update v{0} available'}" />
        <TextBlock Text="{Binding ApiEndpoint}" Foreground="{DynamicResource AccentBrush}"
                   FontSize="11" FontFamily="Cascadia Code,Consolas,monospace" VerticalAlignment="Center" />
        <TextBlock Text="{Binding PlayerCount, StringFormat='Players: {0}'}"
                   Foreground="{DynamicResource TextSecondaryBrush}" FontSize="12"
                   VerticalAlignment="Center" Margin="16,0,0,0" />
        <TextBlock Text="{Binding StatusText}" Foreground="{DynamicResource TextSecondaryBrush}"
                   FontSize="12" VerticalAlignment="Center" Margin="16,0,0,0" />
      </DockPanel>
    </Border>
  </Grid>
</Window>
