<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="GDD.Desktop.Views.PlayerOverlayWindow"
        Title="Player"
        Background="#FF090B1A"
        CanResize="True">
  <Image x:Name="LiveImage" Source="{Binding Thumbnail}" Stretch="Fill" Focusable="True" />
</Window>
