<Window x:Class="GDD.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:GDD.ViewModels"
        xmlns:views="clr-namespace:GDD.Views"
        xmlns:conv="clr-namespace:GDD.Converters"
        Title="GDD — Multi-Browser Testing"
        Width="1400" Height="900"
        MinWidth="800" MinHeight="600"
        Background="{StaticResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Toolbar -->
        <Border Grid.Row="0"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Padding="12,8">
            <DockPanel>
                <!-- Left: Actions -->
                <StackPanel DockPanel.Dock="Left" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="GDD"
                               FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource AccentBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,20,0" />

                    <Button Content="+ Add Player"
                            Style="{StaticResource AccentButton}"
                            Command="{Binding AddPlayerCommand}"
                            Margin="0,0,4,0" />

                    <Button x:Name="PresetMenuButton"
                            Style="{StaticResource ToolbarButton}"
                            Margin="0,0,8,0"
                            Click="OnOpenPresetMenu"
                            ToolTip="Add multiple players with device presets">
                        <Button.Content>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="+ Preset" />
                                <TextBlock Text=" &#x25BC;" FontSize="9" VerticalAlignment="Center" />
                            </StackPanel>
                        </Button.Content>
                    </Button>

                    <Button Content="&#x26A1; Quick Auth All"
                            Style="{StaticResource ToolbarButton}"
                            Command="{Binding QuickAuthAllCommand}"
                            Margin="0,0,4,0" />

                    <Button Content="Close All"
                            Style="{StaticResource ToolbarButton}"
                            Command="{Binding CloseAllCommand}"
                            Margin="0,0,16,0"
                            ToolTip="Close all players and their sessions" />

                    <TextBlock Text="URL:"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               FontSize="12"
                               Margin="0,0,6,0" />
                    <TextBox Text="{Binding DefaultUrl, UpdateSourceTrigger=PropertyChanged}"
                             Width="280"
                             Background="{StaticResource SurfaceLightBrush}"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             BorderBrush="{StaticResource BorderBrush}"
                             Padding="6,4"
                             VerticalAlignment="Center"
                             FontSize="12" />
                    <Button Content="Go"
                            Style="{StaticResource ToolbarButton}"
                            Command="{Binding NavigateAllCommand}"
                            Padding="10,4"
                            Margin="4,0,0,0"
                            ToolTip="Navigate all players to this URL" />
                </StackPanel>

                <!-- Right: Status -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                            VerticalAlignment="Center" HorizontalAlignment="Right">
                    <TextBlock Text="{Binding StatusText}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               FontSize="13" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Video Wall -->
        <Grid Grid.Row="1">
            <ItemsControl ItemsSource="{Binding Players}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <views:VideoWallPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate DataType="{x:Type vm:BrowserCellViewModel}">
                        <views:BrowserCellControl Margin="1" />
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <Image x:Name="MascotImage"
                   Source="C:\VS\GDD\Design\giggly-dazzling-duckling.png"
                   HorizontalAlignment="Left"
                   VerticalAlignment="Center"
                   Margin="20,0,0,0"
                   Opacity="0.1"
                   IsHitTestVisible="True"
                   Stretch="None"
                   MouseLeftButtonDown="OnMascotMouseDown"
                   MouseLeftButtonUp="OnMascotMouseUp" />
        </Grid>

        <!-- Status Bar -->
        <Border Grid.Row="2"
                Background="{StaticResource SurfaceBrush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0"
                Padding="12,4">
            <DockPanel>
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           VerticalAlignment="Center" />
                <TextBlock DockPanel.Dock="Right"
                           Text="{Binding PlayerCount, StringFormat='Players: {0}'}"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="12"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right" />
            </DockPanel>
        </Border>
    </Grid>
</Window>
