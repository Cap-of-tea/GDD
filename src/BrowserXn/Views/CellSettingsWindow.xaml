<Window x:Class="GDD.Views.CellSettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Icon="/app.ico"
        Title="Settings"
        Width="340" Height="520"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundBrush}"
        ShowInTaskbar="False">

    <Window.Resources>
        <Style TargetType="TextBlock" x:Key="LabelStyle">
            <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Margin" Value="0,0,0,4" />
        </Style>
        <Style TargetType="TextBlock" x:Key="SectionHeader">
            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Margin" Value="0,12,0,6" />
        </Style>
        <Style TargetType="ComboBox" x:Key="SettingsCombo">
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Padding" Value="6,4" />
        </Style>
        <Style TargetType="TextBox" x:Key="SettingsTextBox">
            <Setter Property="Background" Value="{StaticResource SurfaceBrush}" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
    </Window.Resources>

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Title -->
        <TextBlock Grid.Row="0"
                   FontSize="15" FontWeight="Bold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   Margin="0,0,0,4">
            <Run x:Name="TitleRun" Text="Player Settings" />
        </TextBlock>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,4,0,8">
            <StackPanel>

                <!-- URL -->
                <TextBlock Text="URL" Style="{StaticResource SectionHeader}" />
                <DockPanel Margin="0,0,0,8">
                    <Button x:Name="GoButton" Content="Go"
                            DockPanel.Dock="Right"
                            Style="{StaticResource AccentButton}"
                            Click="OnGo"
                            Width="40" Margin="6,0,0,0"
                            Padding="4,4" />
                    <TextBox x:Name="UrlBox" Style="{StaticResource SettingsTextBox}"
                             Margin="0" KeyDown="OnUrlKeyDown" />
                </DockPanel>

                <!-- Device -->
                <TextBlock Text="DEVICE" Style="{StaticResource SectionHeader}" />
                <ComboBox x:Name="DeviceCombo"
                          Style="{StaticResource SettingsCombo}"
                          DisplayMemberPath="Name" />

                <!-- Location -->
                <TextBlock Text="LOCATION" Style="{StaticResource SectionHeader}" />
                <ComboBox x:Name="LocationCombo"
                          Style="{StaticResource SettingsCombo}"
                          DisplayMemberPath="CityName" />

                <!-- Network -->
                <TextBlock Text="NETWORK" Style="{StaticResource SectionHeader}" />
                <ComboBox x:Name="NetworkCombo"
                          Style="{StaticResource SettingsCombo}"
                          DisplayMemberPath="Name" />

                <!-- Telegram -->
                <TextBlock Text="TELEGRAM" Style="{StaticResource SectionHeader}" />
                <CheckBox x:Name="TelegramEnabledCheck"
                          Content="Enable Telegram Mode"
                          Foreground="{StaticResource TextPrimaryBrush}"
                          Margin="0,0,0,8" />

                <StackPanel x:Name="TelegramFields"
                            Visibility="Collapsed">
                    <TextBlock Text="TG User ID" Style="{StaticResource LabelStyle}" />
                    <TextBox x:Name="TgUserIdBox" Style="{StaticResource SettingsTextBox}" />

                    <TextBlock Text="TG Username" Style="{StaticResource LabelStyle}" />
                    <TextBox x:Name="TgUsernameBox" Style="{StaticResource SettingsTextBox}" />

                    <TextBlock Text="First Name" Style="{StaticResource LabelStyle}" />
                    <TextBox x:Name="TgFirstNameBox" Style="{StaticResource SettingsTextBox}" />

                    <TextBlock Text="Language" Style="{StaticResource LabelStyle}" />
                    <ComboBox x:Name="TgLanguageCombo" Style="{StaticResource SettingsCombo}">
                        <ComboBoxItem Content="en" IsSelected="True" />
                        <ComboBoxItem Content="ru" />
                        <ComboBoxItem Content="ja" />
                        <ComboBoxItem Content="de" />
                        <ComboBoxItem Content="fr" />
                    </ComboBox>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Buttons -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Cancel"
                    Style="{StaticResource ToolbarButton}"
                    Click="OnCancel"
                    Margin="0,0,8,0" Width="80" />
            <Button Content="Apply"
                    Style="{StaticResource AccentButton}"
                    Click="OnApply"
                    Width="80" />
        </StackPanel>
    </Grid>
</Window>
